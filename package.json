{
  "name": "orbcode",
  "version": "0.1.3",
  "description": "OrbCode CLI — agentic coding in your terminal, powered by Axon models by MatterAI",
  "type": "module",
  "bin": {
    "orbcode": "./bin/orbcode.js"
  },
  "main": "./dist/index.js",
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.tsx",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "ink": "^5.2.1",
    "open": "^10.1.0",
    "openai": "^4.78.0",
    "picomatch": "^4.0.2",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/picomatch": "^3.0.1",
    "@types/react": "^18.3.12",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "orbcode",
    "matterai",
    "axon",
    "cli",
    "ai",
    "coding-agent"
  ],
  "license": "UNLICENSED"
}
