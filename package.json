{
  "name": "@matterailab/orbcode",
  "version": "0.5.8",
  "description": "OrbCode CLI — agentic coding in your terminal, powered by Axon models by MatterAI",
  "type": "module",
  "bin": {
    "orbcode": "./bin/orbcode.js"
  },
  "main": "./dist/index.js",
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MatterAIOrg/OrbCode.git"
  },
  "homepage": "https://github.com/MatterAIOrg/OrbCode#readme",
  "bugs": {
    "url": "https://github.com/MatterAIOrg/OrbCode/issues"
  },
  "author": "MatterAI",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "bun src/index.tsx",
    "start": "bun dist/index.js",
    "test:attachments": "node --import tsx --test test/attachments.test.ts",
    "test:mcp": "node --import tsx --test test/mcp-client.test.ts",
    "test:plugins": "node --import tsx --test test/plugins.test.ts",
    "test:ui": "bun test test/ui-viewport.test.tsx",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.85",
    "@ai-sdk/openai-compatible": "^2.0.51",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentui/core": "0.4.3",
    "@opentui/react": "0.4.3",
    "ai": "^6.0.207",
    "bun": "1.3.14",
    "mammoth": "^1.12.0",
    "open": "^10.1.0",
    "openai": "^4.78.0",
    "pdf-parse": "^2.4.5",
    "picomatch": "^4.0.4",
    "react": "^19.2.0",
    "read-excel-file": "^9.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/picomatch": "^3.0.1",
    "@types/react": "^19.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "orbcode",
    "matterai",
    "axon",
    "cli",
    "ai",
    "coding-agent"
  ],
  "license": "MIT",
  "overrides": {
    "formdata-node": "^6.0.3"
  }
}
